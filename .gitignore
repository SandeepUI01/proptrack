# --- Environment / Secrets (CRITICAL) ---
.env
.env.local
.env.*
backend/.env
frontend/.env

# --- OS / IDE Specific ---
.DS_Store
.vscode/
*.swp

# --- Go (Backend) ---
backend/bin/
backend/obj/
backend/vendor/
